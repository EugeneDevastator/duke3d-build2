{
  "version": 3,
  "configurePresets": [
    {
      "name": "win32-base",
      "hidden": true,
      "generator": "Visual Studio 17 2022",
      "architecture": "Win32",
      "cacheVariables": {
        "CMAKE_POLICY_VERSION_MINIMUM": "3.5"
      },
      "vendor": {
        "jetbrains.com/clion": {
          "toolchain": "Visual Studio"
        }
      }
    },
    {
      "name": "win32-release",
      "inherits": "win32-base",
      "displayName": "RayLua Win32 Release",
      "binaryDir": "${sourceDir}/bin/RELEASE"
    },
    {
      "name": "win32-debug",
      "inherits": "win32-base",
      "displayName": "RayLua Win32 Debug",
      "binaryDir": "${sourceDir}/bin/MYFOLDER"
    }
  ],
  "buildPresets": [
    {
      "name": "win32-release",
      "displayName": "RayLua Win32 Release Build",
      "configurePreset": "win32-release",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "win32-debug",
      "displayName": "RayLua Win32 Debug Build",
      "configurePreset": "win32-debug",
      "configuration": "Debug"
    }
  ]
}
