build RayGame: CXX_EXECUTABLE_LINKER__RayGame_ CMakeFiles/RayGame.dir/main.cpp.o CMakeFiles/RayGame.dir/Core/mapcore.c.o CMakeFiles/RayGame.dir/Core/artloader.c.o CMakeFiles/RayGame.dir/Core/kplib.c.o CMakeFiles/RayGame.dir/Core/loaders.c.o CMakeFiles/RayGame.dir/Core/physics.c.o CMakeFiles/RayGame.dir/Core/monoclip.c.o CMakeFiles/RayGame.dir/Core/scenerender.c.o CMakeFiles/RayGame.dir/Core/shadowtest2.c.o CMakeFiles/RayGame.dir/Core/buildmath.c.o CMakeFiles/RayGame.dir/Core/monodebug.c.o CMakeFiles/RayGame.dir/interfaces/eventstore.c.o | libimgui.a librlimgui.a /usr/lib/libraylib.so libimgui.a /usr/lib/libGLX.so /usr/lib/libOpenGL.so || libimgui.a librlimgui.a
  DEP_FILE = CMakeFiles/RayGame.dir/link.d
  LINK_FLAGS = -Wl,--dependency-file=CMakeFiles/RayGame.dir/link.d
  LINK_LIBRARIES = libimgui.a  librlimgui.a  /usr/lib/libraylib.so  -L/usr/lib -lraylib  libimgui.a  /usr/lib/libGLX.so  /usr/lib/libOpenGL.so
  OBJECT_DIR = CMakeFiles/RayGame.dir
  POST_BUILD = cd /home/jaba/Documentos/raygame/duke3d-build2-main/RayLua/build && /usr/bin/cmake -E copy_if_different /home/jaba/Documentos/raygame/duke3d-build2-main/RayLua/script.lua /home/jaba/Documentos/raygame/duke3d-build2-main/RayLua/build/script.lua && cd /home/jaba/Documentos/raygame/duke3d-build2-main/RayLua/build && /usr/bin/cmake -E make_directory /home/jaba/Documentos/raygame/duke3d-build2-main/RayLua/build/Shaders && /usr/bin/cmake -E copy_directory /home/jaba/Documentos/raygame/duke3d-build2-main/RayLua/Shaders /home/jaba/Documentos/raygame/duke3d-build2-main/RayLua/build/Shaders
  PRE_LINK = :
  TARGET_FILE = RayGame
  TARGET_PDB = RayGame.dbg
  TARGET_SUPPORT_DIR = CMakeFiles/RayGame.dir


